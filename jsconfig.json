{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "checkJs": false,
    "allowJs": true,
    "strict": false,
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "components/**/*",
    "index.html"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "chatappFrontEnd",
    "chatappFrontEnd/**/*"
  ]
}
